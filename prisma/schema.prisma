// Exam Management System — data model
// Roles + access gating (admin dashboard), question bank, and exam building.
// Grading scale defaults to /20 (Lebanese MEHE standard) and is configurable
// per exam.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url = the pooled connection (used at runtime, incl. serverless on Vercel).
  // directUrl = the direct, non-pooled connection (used for db push / migrate).
  // Locally both point at the same Postgres; on Neon they differ.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SCHOOL_ADMIN // restricted admin scoped to a single school (manages its branding + users)
  TEACHER
}

// Admin grants access: new users are PENDING until approved.
enum AccessStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum QuestionType {
  MCQ
  CHECKBOX // multiple correct answers ("select all that apply")
  DROPDOWN // single answer shown as a dropdown
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY // long / paragraph answer
  TEXT // informational text / instructions — no answer, no points
  IMAGE // a picture with an optional title — no answer, no points
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(TEACHER)
  accessStatus AccessStatus @default(PENDING)
  language     String       @default("en") // en | fr | ar
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  questions Question[] @relation("AuthoredQuestions")
  exams     Exam[]     @relation("CreatedExams")

  // Connected Google account (per-teacher OAuth) used to generate Google Forms.
  googleAccount GoogleAccount?
}

// Per-user Google OAuth credentials. A teacher connects their own Google account
// once; their exams' Google Forms are then created in (and owned by) that account.
model GoogleAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleEmail  String? // the connected Google account's email (for display)
  accessToken  String // current OAuth access token (short-lived)
  refreshToken String // long-lived refresh token used to mint new access tokens
  expiresAt    DateTime // when accessToken expires
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Durable, cross-instance counters for rate limiting / brute-force throttling on
// sensitive endpoints (login, registration). Keyed by e.g.
// "login:ip:1.2.3.4" or "login:email:user@x.com". Unlike an in-memory limiter,
// this survives serverless cold starts and is shared across all instances.
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime // when the current window resets

  @@index([expiresAt])
}

// Single-row app branding (used as a fallback when a user/exam has no school).
model AppSetting {
  id          String   @id @default("singleton")
  schoolName  String?
  logoDataUrl String? // data URL (e.g. "data:image/png;base64,...")
  updatedAt   DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

// A purchase placed from the public cart, paid manually via Whish Money.
model Order {
  id         String      @id @default(cuid())
  name       String
  email      String
  schoolName String?
  schools    Int         @default(1) // number of school licenses
  amount     Float // total amount due
  currency   String      @default("USD")
  reference  String? // Whish Money transaction reference entered by the buyer
  proofUrl   String? // screenshot of the Whish Money payment (data URL)
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
}

// Messages submitted via the public "Contact us" form.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// A school groups its own teachers, students, and exams (with its own branding).
model School {
  id          String   @id @default(cuid())
  name        String   @unique
  logoDataUrl String? // per-school logo (data URL)
  themeColor  String? // brand color (hex, e.g. "#1d4ed8") — auto-derived from logo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
  exams Exam[]
}

// Official MEHE subjects (multilingual labels).
model Subject {
  id        String     @id @default(cuid())
  name      String     @unique
  nameAr    String?
  nameFr    String?
  questions Question[]
  exams     Exam[]
}

model Question {
  id            String       @id @default(cuid())
  type          QuestionType
  difficulty    Difficulty   @default(MEDIUM)
  text          String
  imageUrl      String? // optional question image (data URL)
  options       Json? // MCQ: ["A", "B", ...]; null otherwise
  correctAnswer String? // MCQ: option value; TRUE_FALSE: "true"/"false"
  modelAnswer   String? // reference answer / rubric for AI grading of open questions
  keywords      Json? // open questions: keyword rubric [{ "text": string, "points": number }] used to grade essays in-app
  points        Float        @default(1)
  required      Boolean      @default(false) // student must answer before submitting
  language      String       @default("en")

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

  createdById String
  createdBy   User   @relation("AuthoredQuestions", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examQuestions ExamQuestion[]

  @@index([subjectId, difficulty, type])
}

model Exam {
  id               String     @id @default(cuid())
  title            String
  description      String?
  status           ExamStatus @default(DRAFT)
  totalMarks       Float      @default(20) // final score scaled to this (Lebanese /20)
  difficultyConfig Json? // auto-generation mix, e.g. {"easy":40,"medium":40,"hard":20}
  durationMins     Int?
  language         String     @default("en")

  // Google Form generated from this exam (created in the teacher's Google account).
  googleFormId        String? // Forms API form id
  googleFormUrl       String? // responder URL — the link students open to take the exam
  googleFormEditUrl   String? // editor URL — the teacher's link to edit the form
  googleFormCreatedAt DateTime?
  answerKeyReleasedAt DateTime? // when correct answers/points were pushed for grading

  // Answer key uploaded as a PDF and used to AI-grade responses *in-app*
  // (distinct from the Google Forms key above). `answerKey` holds the structured
  // key the AI extracted from the PDF: [{ index, title, answer }], aligned to the
  // exam's gradable questions by position.
  answerKey           Json?
  answerKeyFileName   String?
  answerKeyUploadedAt DateTime?

  // When set, a scheduled job auto-publishes the exam (and opens its Google
  // Form) at this time. Cleared once it fires or the teacher publishes manually.
  scheduledPublishAt DateTime?

  // When set, a scheduled job auto-closes the exam (marks the Google Form
  // closed) at this time. Cleared once it fires or the teacher closes manually.
  scheduledCloseAt DateTime?

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedExams", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examQuestions ExamQuestion[]
  grades        ExamGrade[]
}

// A persisted, teacher-editable grade for one student's Google Form response,
// produced by AI grading the response against the exam's uploaded answer-key
// PDF. Responses themselves live in Google Forms (not stored here); a grade is
// linked back to its response by the Google Forms `responseId`.
model ExamGrade {
  id           String  @id @default(cuid())
  examId       String
  exam         Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  responseId   String // Google Forms response id
  studentEmail String? // respondent email when the form collects it
  // Per-question marks: [{ index, title, maxPoints, aiScore, score, feedback }].
  // `aiScore` is the AI's suggestion; `score` is the current (possibly edited) mark.
  perQuestion Json
  totalScore  Float // sum of per-question `score` (reflects teacher edits)
  maxScore    Float // sum of per-question maxPoints
  aiTotal     Float // the AI's original total, before any teacher edit
  edited      Boolean  @default(false) // true once a teacher overrides any mark
  gradedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([examId, responseId])
}

// Join table: questions placed in an exam, with ordering and optional point override.
model ExamQuestion {
  id         String   @id @default(cuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  order      Int      @default(0)
  points     Float? // overrides Question.points for this exam if set

  @@unique([examId, questionId])
}
